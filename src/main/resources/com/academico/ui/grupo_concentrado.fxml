<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.PieChart?>

<VBox spacing="20" style="-fx-background-color: #F3F4F6; -fx-padding: 28;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.academico.controller.GrupoConcentradoController">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Concentrado Final y Actas"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            <Label fx:id="lblInstrucciones"
                   text="Resumen definitivo de calificaciones. Una vez cerrado el curso, no se podrán realizar más modificaciones."
                   style="-fx-text-fill: #6b7280; -fx-font-size: 13px;" wrapText="true"/>
        </VBox>

        <VBox alignment="CENTER_RIGHT" spacing="4">
            <Label text="Estado de Evaluación:"
                   style="-fx-text-fill: #6b7280; -fx-font-size: 12px;"/>
            <Label fx:id="lblEstadoCurso" text="ABIERTO"
                   style="-fx-font-weight: bold; -fx-font-size: 13px;
                          -fx-text-fill: #028090;
                          -fx-background-color: #e0f5f2;
                          -fx-padding: 4 12; -fx-background-radius: 20;"/>
        </VBox>

        <Button fx:id="btnCerrarCurso" text="Cerrar Curso Definitivamente"
                onAction="#handleCerrarCurso"
                style="-fx-pref-height: 36;
                       -fx-background-color: #ef4444;
                       -fx-text-fill: white;
                       -fx-font-weight: bold;
                       -fx-background-radius: 8;
                       -fx-border-width: 0;
                       -fx-font-size: 13px;
                       -fx-cursor: hand;
                       -fx-padding: 0 16;"/>
    </HBox>

    <!-- Búsqueda -->
    <HBox spacing="12" alignment="CENTER_LEFT"
          style="-fx-background-color: white;
                 -fx-padding: 14;
                 -fx-background-radius: 8;
                 -fx-border-color: #e5e7eb;
                 -fx-border-radius: 8;
                 -fx-border-width: 1;">
        <Label text="Buscar Alumno:"
               style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #1a1a2e;"/>
        <TextField fx:id="campoBusqueda" promptText="Matrícula o Nombre" prefWidth="250"
                   onKeyReleased="#handleBusqueda"
                   style="-fx-pref-height: 36;
                          -fx-background-radius: 8;
                          -fx-border-radius: 8;
                          -fx-border-color: #d1d5db;
                          -fx-border-width: 1;
                          -fx-font-size: 13px;"/>
    </HBox>

    <!-- Tabla + estadísticas -->
    <HBox VBox.vgrow="ALWAYS" spacing="16">
        <TableView fx:id="tablaConcentrado" HBox.hgrow="ALWAYS"
                   style="-fx-background-color: white;
                          -fx-background-radius: 10;
                          -fx-border-radius: 10;
                          -fx-border-color: #e5e7eb;
                          -fx-border-width: 1;
                          -fx-font-size: 13px;">
            <placeholder>
                <Label text="Generando concentrado final..."
                       style="-fx-text-fill: #6b7280; -fx-font-size: 13px;"/>
            </placeholder>
        </TableView>

        <VBox minWidth="280" maxWidth="300" spacing="12" alignment="TOP_CENTER"
              style="-fx-background-color: white;
                     -fx-padding: 24;
                     -fx-background-radius: 10;
                     -fx-border-color: #e5e7eb;
                     -fx-border-radius: 10;
                     -fx-border-width: 1;">
            <Label text="Estadísticas del Grupo"
                   style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #1a1a2e;"/>
            <PieChart fx:id="graficaEstadisticas" legendSide="BOTTOM"
                      labelsVisible="false" VBox.vgrow="ALWAYS"/>
        </VBox>
    </HBox>

    <!-- Panel override -->
    <VBox fx:id="panelOverride" spacing="14" visible="false" managed="false"
          style="-fx-background-color: #fefce8;
                 -fx-padding: 20;
                 -fx-background-radius: 10;
                 -fx-border-color: #fbbf24;
                 -fx-border-radius: 10;
                 -fx-border-width: 1;">

        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label text="Forzar Calificación (Override) para:"
                   style="-fx-text-fill: #6b7280; -fx-font-size: 13px;"/>
            <Label fx:id="lblNombreOverride"
                   style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #1a1a2e;"/>
            <Label text="(Esta acción reemplazará permanentemente el cálculo matemático)"
                   style="-fx-text-fill: #92400e; -fx-font-style: italic; -fx-font-size: 12px;"/>
        </HBox>

        <HBox spacing="16">
            <VBox spacing="4">
                <Label text="Nueva Calificación Final"
                       style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                <TextField fx:id="campoCalificacionManual" prefWidth="150" promptText="Ej. 70.00"
                           style="-fx-pref-height: 36;
                                  -fx-background-radius: 8;
                                  -fx-border-radius: 8;
                                  -fx-border-color: #d1d5db;
                                  -fx-border-width: 1;
                                  -fx-font-size: 13px;"/>
            </VBox>
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Justificación Administrativa (Obligatoria)"
                       style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                <TextField fx:id="campoMotivoOverride"
                           promptText="Ej. Acuerdo de academia / Corrección por fallo en sistema"
                           style="-fx-pref-height: 36;
                                  -fx-background-radius: 8;
                                  -fx-border-radius: 8;
                                  -fx-border-color: #d1d5db;
                                  -fx-border-width: 1;
                                  -fx-font-size: 13px;"/>
            </VBox>
        </HBox>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="Cancelar" onAction="#handleCancelarOverride"
                    style="-fx-pref-height: 36;
                           -fx-background-color: white;
                           -fx-border-color: #d1d5db;
                           -fx-border-width: 1;
                           -fx-border-radius: 8;
                           -fx-background-radius: 8;
                           -fx-font-size: 13px;
                           -fx-cursor: hand;"/>
            <Button text="Aplicar Override" onAction="#handleGuardarOverride"
                    style="-fx-pref-height: 36;
                           -fx-background-color: #f59e0b;
                           -fx-text-fill: white;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-border-width: 0;
                           -fx-font-size: 13px;
                           -fx-cursor: hand;
                           -fx-padding: 0 16;"/>
        </HBox>

        <Label fx:id="lblMensajeOverride" visible="false" managed="false"
               style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
    </VBox>

</VBox>
