<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<ScrollPane fitToWidth="true"
            style="-fx-background-color: #F3F4F6; -fx-control-inner-background: #F3F4F6;"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.academico.controller.MisGruposController">
    <content>
        <VBox spacing="8">
            <padding>
                <Insets bottom="28" left="28" right="28" top="28"/>
            </padding>

            <Label text="Mis Grupos Asignados"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            <Label text="Selecciona un grupo para gestionar rúbricas, calificaciones y concentrados finales."
                   style="-fx-font-size: 13px; -fx-text-fill: #6b7280;"/>

            <Region prefHeight="12"/>

            <Label fx:id="labelCargando" text="Cargando grupos..."
                   style="-fx-font-size: 13px; -fx-text-fill: #00a896; -fx-font-weight: bold;"/>

            <FlowPane fx:id="contenedorTarjetas" hgap="20" vgap="20"/>
        </VBox>
    </content>
</ScrollPane>
