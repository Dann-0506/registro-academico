<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.academico.controller.ConfiguracionController">
    
    <VBox spacing="30" alignment="TOP_CENTER" style="-fx-padding: 50; -fx-background-color: #f8f9fa;">
        
        <VBox alignment="CENTER" spacing="10">
            <Label text="Configuración del Sistema" style="-fx-font-size: 28px; -fx-font-weight: bold;"/>
            <Label text="Ajusta los parámetros globales de evaluación académica." style="-fx-text-fill: #6c757d; -fx-font-size: 14px;"/>
        </VBox>

        <VBox maxWidth="500" spacing="25" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 5); -fx-padding: 40;">
            
            <Label text="Límites de Calificación" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-border-width: 0 0 2 0; -fx-border-color: #e9ecef; -fx-padding: 0 0 10 0;"/>

            <VBox spacing="8">
                <Label text="Calificación Máxima Permitida" style="-fx-font-weight: bold;"/>
                <TextField fx:id="campoMaxima" promptText="Ej. 100" style="-fx-pref-height: 40; -fx-font-size: 16px;"/>
                <Label text="El valor máximo que un docente puede asignar a una actividad o resultado final." style="-fx-text-fill: #6c757d; -fx-font-size: 11px;"/>
            </VBox>

            <VBox spacing="8">
                <Label text="Calificación Mínima Aprobatoria" style="-fx-font-weight: bold;"/>
                <TextField fx:id="campoMinima" promptText="Ej. 70" style="-fx-pref-height: 40; -fx-font-size: 16px;"/>
                <Label text="El puntaje mínimo requerido para que una materia se considere aprobada." style="-fx-text-fill: #6c757d; -fx-font-size: 11px;"/>
            </VBox>

            <HBox alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
                <Button text="Guardar Cambios" onAction="#handleGuardar" styleClass="accent" style="-fx-pref-height: 45; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 0 30;"/>
            </HBox>
        </VBox>

    </VBox>

    <Label fx:id="mensajeGeneral" visible="false" managed="false" wrapText="true" StackPane.alignment="BOTTOM_CENTER" style="-fx-translate-y: -40; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 15, 0, 0, 5);"/>

</StackPane>