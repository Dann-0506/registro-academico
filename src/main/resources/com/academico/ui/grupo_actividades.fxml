<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.academico.controller.GrupoActividadesController">

    <VBox spacing="20" style="-fx-background-color: #F3F4F6; -fx-padding: 28;">

        <!-- Header -->
        <VBox spacing="4">
            <Label text="Rúbrica y Actividades"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            <Label text="Define las actividades evaluables por unidad. La suma debe ser exactamente 100%."
                   style="-fx-text-fill: #6b7280; -fx-font-size: 13px;"/>
        </VBox>

        <!-- Selector unidad -->
        <HBox spacing="12" alignment="CENTER_LEFT"
              style="-fx-background-color: white;
                     -fx-padding: 14;
                     -fx-background-radius: 8;
                     -fx-border-color: #e5e7eb;
                     -fx-border-radius: 8;
                     -fx-border-width: 1;">
            <Label text="Selecciona la Unidad:"
                   style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #1a1a2e;"/>
            <ComboBox fx:id="comboUnidades" prefWidth="250" promptText="-- Elegir Unidad --"
                      style="-fx-pref-height: 36;
                             -fx-background-radius: 8;
                             -fx-border-radius: 8;
                             -fx-border-color: #d1d5db;
                             -fx-border-width: 1;
                             -fx-font-size: 13px;"/>
        </HBox>

        <!-- Panel captura -->
        <HBox fx:id="panelCaptura" spacing="12" alignment="BOTTOM_LEFT" disable="true"
              style="-fx-background-color: white;
                     -fx-padding: 16;
                     -fx-background-radius: 8;
                     -fx-border-color: #e5e7eb;
                     -fx-border-radius: 8;
                     -fx-border-width: 1;">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Nombre de la Actividad"
                       style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                <TextField fx:id="campoNombreActividad"
                           promptText="Ej. Examen, Proyecto..."
                           style="-fx-pref-height: 36;
                                  -fx-background-radius: 8;
                                  -fx-border-radius: 8;
                                  -fx-border-color: #d1d5db;
                                  -fx-border-width: 1;
                                  -fx-font-size: 13px;"/>
            </VBox>
            <VBox spacing="4">
                <Label text="Valor (%)"
                       style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                <TextField fx:id="campoPonderacion" prefWidth="100" promptText="Ej. 30.00"
                           style="-fx-pref-height: 36;
                                  -fx-background-radius: 8;
                                  -fx-border-radius: 8;
                                  -fx-border-color: #d1d5db;
                                  -fx-border-width: 1;
                                  -fx-font-size: 13px;"/>
            </VBox>
            <HBox spacing="8" alignment="BOTTOM_LEFT">
                <Button fx:id="btnCancelarEdicion" text="Cancelar"
                        onAction="#handleCancelarEdicion"
                        visible="false" managed="false"
                        style="-fx-pref-height: 36;
                               -fx-background-color: white;
                               -fx-border-color: #d1d5db;
                               -fx-border-width: 1;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-font-size: 13px;
                               -fx-cursor: hand;"/>
                <Button fx:id="btnGuardarActividad" text="Agregar a Rúbrica"
                        onAction="#handleGuardarActividad"
                        style="-fx-pref-height: 36;
                               -fx-background-color: #00a896;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-border-width: 0;
                               -fx-font-size: 13px;
                               -fx-cursor: hand;
                               -fx-padding: 0 16;"/>
            </HBox>
        </HBox>

        <!-- Tabla -->
        <TableView fx:id="tablaActividades" VBox.vgrow="ALWAYS"
                   style="-fx-background-color: white;
                          -fx-background-radius: 10;
                          -fx-border-radius: 10;
                          -fx-border-color: #e5e7eb;
                          -fx-border-width: 1;
                          -fx-font-size: 13px;">
            <columns>
                <TableColumn fx:id="colNombre" text="Actividad"
                             reorderable="false" resizable="false">
                    <cellValueFactory><PropertyValueFactory property="nombre"/></cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="colPonderacion" text="Ponderación (%)"
                             reorderable="false" resizable="false"
                             style="-fx-alignment: CENTER;">
                    <cellValueFactory><PropertyValueFactory property="ponderacion"/></cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="colAcciones" text="Acciones"
                             reorderable="false" resizable="false"
                             style="-fx-alignment: CENTER;"/>
            </columns>
            <placeholder>
                <Label text="No hay actividades registradas en esta unidad."
                       style="-fx-text-fill: #6b7280; -fx-font-size: 13px;"/>
            </placeholder>
        </TableView>

        <!-- Panel estado -->
        <HBox fx:id="panelEstado" spacing="20" alignment="CENTER_LEFT"
              style="-fx-padding: 14;
                     -fx-background-color: white;
                     -fx-background-radius: 8;
                     -fx-border-color: #e5e7eb;
                     -fx-border-radius: 8;
                     -fx-border-width: 1;">
            <Label fx:id="labelTotal"
                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="labelMensajeValidacion"
                   style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
        </HBox>
    </VBox>

    <!-- Modal confirmación -->
    <StackPane fx:id="panelConfirmacion" visible="false" managed="false"
               style="-fx-background-color: rgba(0,0,0,0.4);">
        <VBox maxWidth="400" maxHeight="-Infinity" spacing="20"
              style="-fx-background-color: white;
                     -fx-background-radius: 12;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5);
                     -fx-padding: 30;">
            <Label fx:id="lblTituloConfirmacion"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            <Label fx:id="lblMensajeConfirmacion" wrapText="true"
                   style="-fx-text-fill: #6b7280; -fx-font-size: 13px;"/>
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button text="Cancelar" onAction="#handleCancelarConfirmacion"
                        style="-fx-pref-height: 36;
                               -fx-background-color: white;
                               -fx-border-color: #d1d5db;
                               -fx-border-width: 1;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-font-size: 13px;
                               -fx-cursor: hand;"/>
                <Button fx:id="btnConfirmarAccion" onAction="#handleEjecutarConfirmacion"
                        style="-fx-pref-height: 36;
                               -fx-background-color: #00a896;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-border-width: 0;
                               -fx-font-size: 13px;
                               -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </StackPane>

</StackPane>
