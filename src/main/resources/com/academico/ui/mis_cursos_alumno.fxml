<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="24" style="-fx-background-color: #F3F4F6; -fx-padding: 28;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.academico.controller.MisCursosAlumnoController">

    <VBox spacing="4">
        <Label text="Mi Historial Académico"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
        <Label text="Consulta tus cursos actuales y el registro histórico de tus semestres anteriores."
               style="-fx-text-fill: #6b7280; -fx-font-size: 13px;"/>
    </VBox>

    <Label fx:id="labelCargando" text="Cargando cursos..."
           style="-fx-font-size: 13px; -fx-text-fill: #6b7280;"/>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent;
                       -fx-background: transparent;
                       -fx-border-color: transparent;">
        <content>
            <FlowPane fx:id="contenedorTarjetas" hgap="16" vgap="16">
                <padding>
                    <Insets bottom="20" left="4" right="4" top="4"/>
                </padding>
            </FlowPane>
        </content>
    </ScrollPane>

</VBox>
