<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.academico.controller.GruposController">

    <VBox spacing="20" style="-fx-padding: 28; -fx-background-color: #F3F4F6;">

        <HBox alignment="CENTER_LEFT" spacing="12">
            <Label text="Catálogo de Grupos Académicos"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Importar CSV" onAction="#handleImportarCSV"
                    style="-fx-pref-height: 36;
                           -fx-background-color: white;
                           -fx-border-color: #d1d5db;
                           -fx-border-width: 1;
                           -fx-border-radius: 8;
                           -fx-background-radius: 8;
                           -fx-font-size: 13px;
                           -fx-cursor: hand;">
                <tooltip>
                    <Tooltip text="Formato esperado:&#10;• CLAVE DE LA MATERIA&#10;• NUM DE EMPLEADO&#10;• CLAVE DEL GRUPO&#10;• SEMESTRE"/>
                </tooltip>
            </Button>
            <TextField fx:id="campoBusqueda"
                       promptText="Buscar por clave, materia o docente..."
                       onKeyReleased="#handleBusqueda"
                       prefWidth="250"
                       style="-fx-pref-height: 36;
                              -fx-background-radius: 8;
                              -fx-border-radius: 8;
                              -fx-border-color: #d1d5db;
                              -fx-border-width: 1;
                              -fx-font-size: 13px;
                              -fx-background-color: white;"/>
            <Button text="+ Nuevo Grupo" onAction="#handleNuevo"
                    style="-fx-pref-height: 36;
                           -fx-font-weight: bold;
                           -fx-font-size: 13px;
                           -fx-background-color: #00a896;
                           -fx-text-fill: white;
                           -fx-background-radius: 8;
                           -fx-border-width: 0;
                           -fx-cursor: hand;
                           -fx-padding: 0 16;"/>
        </HBox>

        <TableView fx:id="tablaGrupos" VBox.vgrow="ALWAYS"
                   style="-fx-background-color: white;
                          -fx-background-radius: 10;
                          -fx-border-radius: 10;
                          -fx-border-color: #e5e7eb;
                          -fx-border-width: 1;
                          -fx-font-size: 13px;">
            <placeholder>
                <Label text="No se encontraron grupos registrados para este ciclo."
                       style="-fx-text-fill: #6b7280; -fx-font-size: 13px;"/>
            </placeholder>
            <columns>
                <TableColumn fx:id="colClave" text="Clave" prefWidth="100"/>
                <TableColumn fx:id="colMateria" text="Materia" prefWidth="250"/>
                <TableColumn fx:id="colMaestro" text="Maestro" prefWidth="200"/>
                <TableColumn fx:id="colSemestre" text="Semestre" prefWidth="100"/>
                <TableColumn fx:id="colEstadoEvaluacion" text="Evaluación" prefWidth="120"/>
                <TableColumn fx:id="colEstado" text="Estado" prefWidth="100"/>
                <TableColumn fx:id="colAcciones" text="Acciones" prefWidth="220"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_FLEX_LAST_COLUMN"/>
            </columnResizePolicy>
        </TableView>

        <Pagination fx:id="paginacionGrupos" maxPageIndicatorCount="5"/>

    </VBox>

    <!-- Modal formulario -->
    <StackPane fx:id="panelFormulario" visible="false" managed="false"
               style="-fx-background-color: rgba(0,0,0,0.4);">
        <VBox maxWidth="450" maxHeight="-Infinity" spacing="20"
              style="-fx-background-color: white;
                     -fx-background-radius: 12;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5);
                     -fx-padding: 30;">

            <Label fx:id="labelTituloFormulario" text="Nuevo Grupo"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>

            <VBox spacing="5">
                <Label text="Materia *" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                <ComboBox fx:id="cbMateria" maxWidth="Infinity" editable="true"
                          promptText="Seleccione o busque materia..."
                          style="-fx-pref-height: 36;
                                 -fx-background-radius: 8;
                                 -fx-border-radius: 8;
                                 -fx-border-color: #d1d5db;
                                 -fx-border-width: 1;
                                 -fx-font-size: 13px;"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Docente *" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                <ComboBox fx:id="cbMaestro" maxWidth="Infinity" editable="true"
                          promptText="Seleccione o busque docente..."
                          style="-fx-pref-height: 36;
                                 -fx-background-radius: 8;
                                 -fx-border-radius: 8;
                                 -fx-border-color: #d1d5db;
                                 -fx-border-width: 1;
                                 -fx-font-size: 13px;"/>
            </VBox>

            <HBox spacing="12">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Clave del Grupo *" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                    <TextField fx:id="campoClave" promptText="Ej. MAT-101-A"
                               style="-fx-pref-height: 36;
                                      -fx-background-radius: 8;
                                      -fx-border-radius: 8;
                                      -fx-border-color: #d1d5db;
                                      -fx-border-width: 1;
                                      -fx-font-size: 13px;"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Semestre *" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                    <TextField fx:id="campoSemestre" promptText="Ej. 2024-1"
                               style="-fx-pref-height: 36;
                                      -fx-background-radius: 8;
                                      -fx-border-radius: 8;
                                      -fx-border-color: #d1d5db;
                                      -fx-border-width: 1;
                                      -fx-font-size: 13px;"/>
                </VBox>
            </HBox>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Cancelar" onAction="#handleCancelar"
                        style="-fx-pref-height: 36;
                               -fx-background-color: white;
                               -fx-border-color: #d1d5db;
                               -fx-border-width: 1;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-font-size: 13px;
                               -fx-cursor: hand;"/>
                <Button text="Guardar" onAction="#handleGuardar"
                        style="-fx-pref-height: 36;
                               -fx-background-color: #00a896;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-border-width: 0;
                               -fx-font-size: 13px;
                               -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </StackPane>

    <!-- Modal confirmación -->
    <StackPane fx:id="panelConfirmacion" visible="false" managed="false"
               style="-fx-background-color: rgba(0,0,0,0.5);">
        <VBox maxWidth="400" maxHeight="-Infinity" spacing="15"
              style="-fx-background-color: white;
                     -fx-background-radius: 12;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5);
                     -fx-padding: 30;">

            <Label fx:id="lblTituloConfirmacion"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            <Label fx:id="lblMensajeConfirmacion" wrapText="true"
                   style="-fx-text-fill: #6b7280; -fx-font-size: 14px;"/>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button text="Cancelar" onAction="#handleCancelarConfirmacion"
                        style="-fx-pref-height: 36;
                               -fx-background-color: white;
                               -fx-border-color: #d1d5db;
                               -fx-border-width: 1;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-font-size: 13px;
                               -fx-cursor: hand;"/>
                <Button fx:id="btnConfirmarAccion" text="Confirmar"
                        onAction="#handleEjecutarConfirmacion"
                        style="-fx-pref-height: 36;
                               -fx-background-color: #00a896;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-border-width: 0;
                               -fx-font-size: 13px;
                               -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </StackPane>

    <Label fx:id="mensajeGeneral" visible="false" managed="false" wrapText="true"
           StackPane.alignment="BOTTOM_CENTER"
           style="-fx-translate-y: -40;
                  -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 15, 0, 0, 5);
                  -fx-background-radius: 8;
                  -fx-padding: 10 16;
                  -fx-font-size: 13px;"/>

</StackPane>
