<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.academico.controller.RespaldosController">

    <VBox spacing="20" style="-fx-padding: 28; -fx-background-color: #F3F4F6;">

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="12">
            <VBox spacing="4">
                <Label text="Administración de Respaldos"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                <Label text="Crea, descarga y restaura copias de seguridad físicas de la base de datos."
                       style="-fx-text-fill: #6b7280; -fx-font-size: 12px;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Generar Nuevo Respaldo Ahora" onAction="#handleCrearRespaldo"
                    style="-fx-pref-height: 40;
                           -fx-font-weight: bold;
                           -fx-font-size: 13px;
                           -fx-padding: 0 20;
                           -fx-background-color: #02c39a;
                           -fx-text-fill: white;
                           -fx-background-radius: 8;
                           -fx-border-width: 0;
                           -fx-cursor: hand;"/>
        </HBox>

        <!-- Tabla -->
        <TableView fx:id="tablaRespaldos" VBox.vgrow="ALWAYS"
                   style="-fx-background-color: white;
                          -fx-background-radius: 10;
                          -fx-border-radius: 10;
                          -fx-border-color: #e5e7eb;
                          -fx-border-width: 1;
                          -fx-font-size: 13px;">
            <placeholder>
                <Label text="No se encontraron respaldos en la carpeta local."
                       style="-fx-text-fill: #6b7280; -fx-font-size: 13px;"/>
            </placeholder>
            <columns>
                <TableColumn fx:id="colNombre" text="Nombre del Archivo" prefWidth="300"/>
                <TableColumn fx:id="colFecha" text="Fecha de Creación" prefWidth="200"
                             style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="colTamano" text="Tamaño" prefWidth="120"
                             style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="colAcciones" text="Acciones Críticas" prefWidth="250"
                             style="-fx-alignment: CENTER;"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_FLEX_LAST_COLUMN"/>
            </columnResizePolicy>
        </TableView>
    </VBox>

    <!-- Modal confirmación -->
    <StackPane fx:id="panelConfirmacion" visible="false" managed="false"
               style="-fx-background-color: rgba(0,0,0,0.6);">
        <VBox maxWidth="450" maxHeight="-Infinity" spacing="15"
              style="-fx-background-color: white;
                     -fx-background-radius: 12;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 20, 0, 0, 5);
                     -fx-padding: 30;
                     -fx-border-color: #ef4444;
                     -fx-border-width: 4 0 0 0;
                     -fx-border-radius: 12;">

            <Label fx:id="lblTituloConfirmacion"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #ef4444;"/>
            <Label fx:id="lblMensajeConfirmacion" wrapText="true"
                   style="-fx-text-fill: #6b7280; -fx-font-size: 13px;"/>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button text="Cancelar" onAction="#handleCancelarConfirmacion"
                        style="-fx-pref-height: 38;
                               -fx-font-weight: bold;
                               -fx-background-color: white;
                               -fx-border-color: #d1d5db;
                               -fx-border-width: 1;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-font-size: 13px;
                               -fx-cursor: hand;"/>
                <Button fx:id="btnConfirmarAccion" text="¡ESTOY SEGURO, CONTINUAR!"
                        onAction="#handleEjecutarConfirmacion"
                        style="-fx-pref-height: 38;
                               -fx-font-weight: bold;
                               -fx-background-color: #ef4444;
                               -fx-text-fill: white;
                               -fx-background-radius: 8;
                               -fx-border-width: 0;
                               -fx-font-size: 13px;
                               -fx-cursor: hand;
                               -fx-padding: 0 16;"/>
            </HBox>
        </VBox>
    </StackPane>

    <Label fx:id="mensajeGeneral" visible="false" managed="false" wrapText="true"
           StackPane.alignment="BOTTOM_CENTER"
           style="-fx-translate-y: -40;
                  -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 15, 0, 0, 5);
                  -fx-background-radius: 8;
                  -fx-padding: 10 16;
                  -fx-font-size: 13px;"/>

    <!-- Panel carga -->
    <StackPane fx:id="panelCarga" visible="false" managed="false"
               style="-fx-background-color: rgba(255,255,255,0.85);">
        <VBox alignment="CENTER" spacing="14">
            <ProgressIndicator prefWidth="48" prefHeight="48"
                               style="-fx-accent: #00a896;"/>
            <Label text="Procesando base de datos. Por favor, no cierres el sistema..."
                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
        </VBox>
    </StackPane>

</StackPane>
