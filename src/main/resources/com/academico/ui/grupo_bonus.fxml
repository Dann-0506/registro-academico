<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" style="-fx-background-color: #F3F4F6; -fx-padding: 28;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.academico.controller.GrupoBonusController">

    <!-- Header -->
    <VBox spacing="4">
        <Label text="Asignar Puntos Extra"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
        <Label text="Otorga bonificaciones directas sobre la calificación final de una unidad o de la materia completa."
               style="-fx-text-fill: #6b7280; -fx-font-size: 13px;" wrapText="true"/>
    </VBox>

    <!-- Búsqueda -->
    <HBox spacing="12" alignment="CENTER_LEFT"
          style="-fx-background-color: white;
                 -fx-padding: 14;
                 -fx-background-radius: 8;
                 -fx-border-color: #e5e7eb;
                 -fx-border-radius: 8;
                 -fx-border-width: 1;">
        <Label text="Buscar Alumno:"
               style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #1a1a2e;"/>
        <TextField fx:id="campoBusqueda" promptText="Matrícula o Nombre" prefWidth="250"
                   onKeyReleased="#handleBusquedaAlumno"
                   style="-fx-pref-height: 36;
                          -fx-background-radius: 8;
                          -fx-border-radius: 8;
                          -fx-border-color: #d1d5db;
                          -fx-border-width: 1;
                          -fx-font-size: 13px;"/>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <!-- Tabla alumnos -->
    <TableView fx:id="tablaAlumnos" VBox.vgrow="ALWAYS"
               style="-fx-background-color: white;
                      -fx-background-radius: 10;
                      -fx-border-radius: 10;
                      -fx-border-color: #e5e7eb;
                      -fx-border-width: 1;
                      -fx-font-size: 13px;">
        <placeholder>
            <Label text="Cargando información académica de los alumnos..."
                   style="-fx-text-fill: #6b7280; -fx-font-size: 13px;"/>
        </placeholder>
    </TableView>

    <!-- Panel asignación -->
    <VBox fx:id="panelAsignacion" spacing="16" visible="false" managed="false"
          style="-fx-background-color: white;
                 -fx-padding: 20;
                 -fx-background-radius: 10;
                 -fx-border-color: #00a896;
                 -fx-border-radius: 10;
                 -fx-border-width: 1;">

        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label text="Otorgando puntos a:"
                   style="-fx-text-fill: #6b7280; -fx-font-size: 13px;"/>
            <Label fx:id="lblNombreSeleccionado"
                   style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #1a1a2e;"/>
        </HBox>

        <HBox spacing="16">
            <VBox spacing="4">
                <Label text="¿Dónde aplicar?"
                       style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                <ComboBox fx:id="comboTipoAplicacion" prefWidth="200"
                          promptText="-- Seleccionar --"
                          style="-fx-pref-height: 36;
                                 -fx-background-radius: 8;
                                 -fx-border-radius: 8;
                                 -fx-border-color: #d1d5db;
                                 -fx-border-width: 1;
                                 -fx-font-size: 13px;"/>
            </VBox>

            <VBox spacing="4">
                <Label text="Puntos (+)"
                       style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                <TextField fx:id="campoPuntos" prefWidth="100" promptText="Ej. 5"
                           style="-fx-pref-height: 36;
                                  -fx-background-radius: 8;
                                  -fx-border-radius: 8;
                                  -fx-border-color: #d1d5db;
                                  -fx-border-width: 1;
                                  -fx-font-size: 13px;"/>
            </VBox>

            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Motivo / Justificación"
                       style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                <TextField fx:id="campoMotivo" promptText="Ej. Participación destacada en el debate"
                           style="-fx-pref-height: 36;
                                  -fx-background-radius: 8;
                                  -fx-border-radius: 8;
                                  -fx-border-color: #d1d5db;
                                  -fx-border-width: 1;
                                  -fx-font-size: 13px;"/>
            </VBox>
        </HBox>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="Cancelar" onAction="#handleCancelar"
                    style="-fx-pref-height: 36;
                           -fx-background-color: white;
                           -fx-border-color: #d1d5db;
                           -fx-border-width: 1;
                           -fx-border-radius: 8;
                           -fx-background-radius: 8;
                           -fx-font-size: 13px;
                           -fx-cursor: hand;"/>
            <Button fx:id="btnGuardarPuntos" text="Guardar Puntos Extra"
                    onAction="#handleGuardarPuntos"
                    style="-fx-pref-height: 36;
                           -fx-background-color: #00a896;
                           -fx-text-fill: white;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-border-width: 0;
                           -fx-font-size: 13px;
                           -fx-cursor: hand;
                           -fx-padding: 0 16;"/>
        </HBox>

        <Label fx:id="lblMensajeFormulario" visible="false" managed="false"
               style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
    </VBox>

</VBox>
