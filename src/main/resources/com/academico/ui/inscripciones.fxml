<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.academico.controller.InscripcionesController">

    <VBox spacing="20" style="-fx-padding: 28; -fx-background-color: #F3F4F6;">

        <HBox alignment="CENTER_LEFT" spacing="12">
            <Label text="Gestión de Inscripciones"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Importar CSV" onAction="#handleImportarCsv"
                    style="-fx-pref-height: 36;
                           -fx-background-color: white;
                           -fx-border-color: #d1d5db;
                           -fx-border-width: 1;
                           -fx-border-radius: 8;
                           -fx-background-radius: 8;
                           -fx-font-size: 13px;
                           -fx-cursor: hand;">
                <tooltip>
                    <Tooltip text="Formato esperado:&#10;• Matrícula del Alumno&#10;• Clave del Grupo&#10;• Semestre"/>
                </tooltip>
            </Button>
            <TextField fx:id="campoBusqueda"
                       promptText="Buscar alumno, matrícula o grupo..."
                       onKeyReleased="#handleBusqueda"
                       prefWidth="300"
                       style="-fx-pref-height: 36;
                              -fx-background-radius: 8;
                              -fx-border-radius: 8;
                              -fx-border-color: #d1d5db;
                              -fx-border-width: 1;
                              -fx-font-size: 13px;
                              -fx-background-color: white;"/>
            <Button text="+ Nueva Inscripción" onAction="#handleNuevo"
                    style="-fx-pref-height: 36;
                           -fx-font-weight: bold;
                           -fx-font-size: 13px;
                           -fx-background-color: #00a896;
                           -fx-text-fill: white;
                           -fx-background-radius: 8;
                           -fx-border-width: 0;
                           -fx-cursor: hand;
                           -fx-padding: 0 16;"/>
        </HBox>

        <TableView fx:id="tablaInscripciones" VBox.vgrow="ALWAYS"
                   style="-fx-background-color: white;
                          -fx-background-radius: 10;
                          -fx-border-radius: 10;
                          -fx-border-color: #e5e7eb;
                          -fx-border-width: 1;
                          -fx-font-size: 13px;">
            <placeholder>
                <Label text="No hay inscripciones registradas en el sistema."
                       style="-fx-text-fill: #6b7280; -fx-font-size: 13px;"/>
            </placeholder>
            <columns>
                <TableColumn fx:id="colMatricula" text="Matrícula" prefWidth="120"/>
                <TableColumn fx:id="colAlumno" text="Alumno" prefWidth="250"/>
                <TableColumn fx:id="colGrupoClave" text="Grupo" prefWidth="100"
                             style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="colMateria" text="Materia" prefWidth="200"/>
                <TableColumn fx:id="colSemestre" text="Semestre" prefWidth="100"
                             style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="colFecha" text="Fecha Inscripción" prefWidth="120"
                             style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="colAcciones" text="Acciones" prefWidth="100"
                             style="-fx-alignment: CENTER;"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_FLEX_LAST_COLUMN"/>
            </columnResizePolicy>
        </TableView>

        <Pagination fx:id="paginacionInscripciones" maxPageIndicatorCount="5"/>

    </VBox>

    <!-- Modal formulario -->
    <StackPane fx:id="panelFormulario" visible="false" managed="false"
               style="-fx-background-color: rgba(0,0,0,0.4);">
        <VBox maxWidth="500" maxHeight="-Infinity" spacing="20"
              style="-fx-background-color: white;
                     -fx-background-radius: 12;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5);
                     -fx-padding: 30;">

            <Label text="Inscribir Alumno a Grupo"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>

            <VBox spacing="5">
                <Label text="Seleccionar Alumno *" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                <ComboBox fx:id="cbAlumno" maxWidth="Infinity" editable="true"
                          promptText="Buscar por nombre o matrícula..."
                          style="-fx-pref-height: 36;
                                 -fx-background-radius: 8;
                                 -fx-border-radius: 8;
                                 -fx-border-color: #d1d5db;
                                 -fx-border-width: 1;
                                 -fx-font-size: 13px;"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Seleccionar Grupo *" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                <ComboBox fx:id="cbGrupo" maxWidth="Infinity" editable="true"
                          promptText="Buscar por clave o materia..."
                          style="-fx-pref-height: 36;
                                 -fx-background-radius: 8;
                                 -fx-border-radius: 8;
                                 -fx-border-color: #d1d5db;
                                 -fx-border-width: 1;
                                 -fx-font-size: 13px;"/>
                <Label text="Nota: Solo se muestran grupos marcados como 'ACTIVOS'."
                       style="-fx-text-fill: #6b7280; -fx-font-size: 11px;"/>
            </VBox>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Cancelar" onAction="#handleCancelar"
                        style="-fx-pref-height: 36;
                               -fx-background-color: white;
                               -fx-border-color: #d1d5db;
                               -fx-border-width: 1;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-font-size: 13px;
                               -fx-cursor: hand;"/>
                <Button text="Inscribir" onAction="#handleGuardar"
                        style="-fx-pref-height: 36;
                               -fx-background-color: #00a896;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-border-width: 0;
                               -fx-font-size: 13px;
                               -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </StackPane>

    <!-- Modal confirmación -->
    <StackPane fx:id="panelConfirmacion" visible="false" managed="false"
               style="-fx-background-color: rgba(0,0,0,0.5);">
        <VBox maxWidth="400" maxHeight="-Infinity" spacing="15"
              style="-fx-background-color: white;
                     -fx-background-radius: 12;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5);
                     -fx-padding: 30;">

            <Label fx:id="lblTituloConfirmacion"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            <Label fx:id="lblMensajeConfirmacion" wrapText="true"
                   style="-fx-text-fill: #6b7280; -fx-font-size: 14px;"/>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button text="Cancelar" onAction="#handleCancelarConfirmacion"
                        style="-fx-pref-height: 36;
                               -fx-background-color: white;
                               -fx-border-color: #d1d5db;
                               -fx-border-width: 1;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-font-size: 13px;
                               -fx-cursor: hand;"/>
                <Button fx:id="btnConfirmarAccion" text="Confirmar Baja"
                        onAction="#handleEjecutarConfirmacion"
                        style="-fx-pref-height: 36;
                               -fx-background-color: #ef4444;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-border-width: 0;
                               -fx-font-size: 13px;
                               -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </StackPane>

    <Label fx:id="mensajeGeneral" visible="false" managed="false" wrapText="true"
           StackPane.alignment="BOTTOM_CENTER"
           style="-fx-translate-y: -40;
                  -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 15, 0, 0, 5);
                  -fx-background-radius: 8;
                  -fx-padding: 10 16;
                  -fx-font-size: 13px;"/>

</StackPane>
