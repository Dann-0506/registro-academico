<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.academico.controller.MateriasController">

    <VBox spacing="20" style="-fx-padding: 28; -fx-background-color: #F3F4F6;">

        <HBox alignment="CENTER_LEFT" spacing="12">
            <Label text="Catálogo de Materias"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Importar CSV" onAction="#handleImportarCsv"
                    style="-fx-pref-height: 36;
                           -fx-background-color: white;
                           -fx-border-color: #d1d5db;
                           -fx-border-width: 1;
                           -fx-border-radius: 8;
                           -fx-background-radius: 8;
                           -fx-font-size: 13px;
                           -fx-cursor: hand;">
                <tooltip>
                    <Tooltip text="Formato esperado:&#10;• CLAVE&#10;• NOMBRE DE LA MATERIA&#10;• TOTAL DE UNIDADES&#10;• NOMBRES DE UNIDADES (Opcional, separados por |)"/>
                </tooltip>
            </Button>
            <TextField fx:id="campoBusqueda"
                       promptText="Buscar clave o nombre..."
                       onKeyReleased="#handleBusqueda"
                       prefWidth="250"
                       style="-fx-pref-height: 36;
                              -fx-background-radius: 8;
                              -fx-border-radius: 8;
                              -fx-border-color: #d1d5db;
                              -fx-border-width: 1;
                              -fx-font-size: 13px;
                              -fx-background-color: white;"/>
            <Button text="+ Nueva Materia" onAction="#handleNuevo"
                    style="-fx-pref-height: 36;
                           -fx-font-weight: bold;
                           -fx-font-size: 13px;
                           -fx-background-color: #00a896;
                           -fx-text-fill: white;
                           -fx-background-radius: 8;
                           -fx-border-width: 0;
                           -fx-cursor: hand;
                           -fx-padding: 0 16;"/>
        </HBox>

        <TableView fx:id="tablaMaterias" VBox.vgrow="ALWAYS"
                   style="-fx-background-color: white;
                          -fx-background-radius: 10;
                          -fx-border-radius: 10;
                          -fx-border-color: #e5e7eb;
                          -fx-border-width: 1;
                          -fx-font-size: 13px;">
            <placeholder>
                <Label text="No se encontraron materias registradas."
                       style="-fx-text-fill: #6b7280; -fx-font-size: 13px;"/>
            </placeholder>
            <columns>
                <TableColumn fx:id="colClave" text="Clave" prefWidth="100"/>
                <TableColumn fx:id="colNombre" text="Nombre de la Materia" prefWidth="350"/>
                <TableColumn fx:id="colTotalUnidades" text="Unidades" prefWidth="100"
                             style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="colAcciones" text="Acciones" prefWidth="250"
                             style="-fx-alignment: CENTER;"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_FLEX_LAST_COLUMN"/>
            </columnResizePolicy>
        </TableView>

        <Pagination fx:id="paginacionMaterias" maxPageIndicatorCount="5"/>

    </VBox>

    <!-- Modal formulario -->
    <StackPane fx:id="panelFormulario" visible="false" managed="false"
               style="-fx-background-color: rgba(0,0,0,0.4);">
        <VBox maxWidth="450" maxHeight="-Infinity" spacing="20"
              style="-fx-background-color: white;
                     -fx-background-radius: 12;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5);
                     -fx-padding: 30;">

            <Label fx:id="labelTituloFormulario" text="Nueva Materia"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>

            <VBox spacing="5">
                <Label text="Clave *" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                <TextField fx:id="campoClave" promptText="Ej. MAT-101"
                           style="-fx-pref-height: 36;
                                  -fx-background-radius: 8;
                                  -fx-border-radius: 8;
                                  -fx-border-color: #d1d5db;
                                  -fx-border-width: 1;
                                  -fx-font-size: 13px;"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Nombre de la Materia *" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                <TextField fx:id="campoNombreMateria" promptText="Ej. Matemáticas Discretas"
                           style="-fx-pref-height: 36;
                                  -fx-background-radius: 8;
                                  -fx-border-radius: 8;
                                  -fx-border-color: #d1d5db;
                                  -fx-border-width: 1;
                                  -fx-font-size: 13px;"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Total de Unidades *" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                <TextField fx:id="campoTotalUnidades" promptText="Ej. 5"
                           style="-fx-pref-height: 36;
                                  -fx-background-radius: 8;
                                  -fx-border-radius: 8;
                                  -fx-border-color: #d1d5db;
                                  -fx-border-width: 1;
                                  -fx-font-size: 13px;"/>
            </VBox>

            <Label text="Nota: Las unidades no se pueden alterar una vez creada la materia por seguridad académica."
                   style="-fx-text-fill: #6b7280; -fx-font-size: 11px;"
                   wrapText="true"/>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button text="Cancelar" onAction="#handleCancelar"
                        style="-fx-pref-height: 36;
                               -fx-background-color: white;
                               -fx-border-color: #d1d5db;
                               -fx-border-width: 1;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-font-size: 13px;
                               -fx-cursor: hand;"/>
                <Button text="Guardar" onAction="#handleGuardar"
                        style="-fx-pref-height: 36;
                               -fx-background-color: #00a896;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-border-width: 0;
                               -fx-font-size: 13px;
                               -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </StackPane>

    <!-- Panel unidades -->
    <StackPane fx:id="panelUnidades" visible="false" managed="false"
               style="-fx-background-color: rgba(0,0,0,0.5);">
        <VBox maxWidth="550" maxHeight="500" spacing="15"
              style="-fx-background-color: white;
                     -fx-background-radius: 12;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5);
                     -fx-padding: 30;">

            <Label fx:id="lblTituloUnidades" text="Unidades de la Materia"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>

            <TableView fx:id="tablaUnidades" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: white;
                              -fx-background-radius: 8;
                              -fx-border-radius: 8;
                              -fx-border-color: #e5e7eb;
                              -fx-border-width: 1;
                              -fx-font-size: 13px;">
                <placeholder>
                    <Label text="No hay unidades registradas."
                           style="-fx-text-fill: #6b7280; -fx-font-size: 13px;"/>
                </placeholder>
                <columns>
                    <TableColumn fx:id="colUnidadNumero" text="No." prefWidth="60"
                                 style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colUnidadNombre" text="Nombre Temático de la Unidad" prefWidth="400"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_FLEX_LAST_COLUMN"/>
                </columnResizePolicy>
            </TableView>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="campoNombreUnidad"
                           promptText="Selecciona una unidad en la tabla para renombrarla..."
                           HBox.hgrow="ALWAYS" disable="true"
                           style="-fx-pref-height: 36;
                                  -fx-background-radius: 8;
                                  -fx-border-radius: 8;
                                  -fx-border-color: #d1d5db;
                                  -fx-border-width: 1;
                                  -fx-font-size: 13px;"/>
                <Button fx:id="btnGuardarUnidad" text="Actualizar Nombre"
                        onAction="#handleGuardarNombreUnidad" disable="true"
                        style="-fx-pref-height: 36;
                               -fx-background-color: #00a896;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-border-width: 0;
                               -fx-font-size: 13px;
                               -fx-cursor: hand;"/>
            </HBox>

            <HBox alignment="CENTER_RIGHT">
                <Button text="Cerrar Panel" onAction="#handleCerrarUnidades"
                        style="-fx-pref-height: 36;
                               -fx-background-color: white;
                               -fx-border-color: #d1d5db;
                               -fx-border-width: 1;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-font-size: 13px;
                               -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </StackPane>

    <!-- Modal confirmación -->
    <StackPane fx:id="panelConfirmacion" visible="false" managed="false"
               style="-fx-background-color: rgba(0,0,0,0.5);">
        <VBox maxWidth="400" maxHeight="-Infinity" spacing="15"
              style="-fx-background-color: white;
                     -fx-background-radius: 12;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5);
                     -fx-padding: 30;">

            <Label fx:id="lblTituloConfirmacion"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            <Label fx:id="lblMensajeConfirmacion" wrapText="true"
                   style="-fx-text-fill: #6b7280; -fx-font-size: 14px;"/>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button text="Cancelar" onAction="#handleCancelarConfirmacion"
                        style="-fx-pref-height: 36;
                               -fx-background-color: white;
                               -fx-border-color: #d1d5db;
                               -fx-border-width: 1;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-font-size: 13px;
                               -fx-cursor: hand;"/>
                <Button fx:id="btnConfirmarAccion" text="Confirmar"
                        onAction="#handleEjecutarConfirmacion"
                        style="-fx-pref-height: 36;
                               -fx-background-color: #00a896;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-border-width: 0;
                               -fx-font-size: 13px;
                               -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </StackPane>

    <Label fx:id="mensajeGeneral" visible="false" managed="false" wrapText="true"
           StackPane.alignment="BOTTOM_CENTER"
           style="-fx-translate-y: -40;
                  -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 15, 0, 0, 5);
                  -fx-background-radius: 8;
                  -fx-padding: 10 16;
                  -fx-font-size: 13px;"/>

</StackPane>
