<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.academico.controller.DashboardAlumnoController">

    <BorderPane>
        <left>
            <VBox spacing="0" prefWidth="240" minWidth="240" style="-fx-background-color: -color-bg-subtle; -fx-border-color: -color-border-default; -fx-border-width: 0 1 0 0;">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

                <VBox spacing="2">
                    <padding><Insets bottom="12"/></padding>
                    <Label fx:id="labelNombreUsuario" text="Cargando..." styleClass="text-bold" style="-fx-font-size: 14px;"/>
                    <Label fx:id="labelMatricula" styleClass="text-muted" style="-fx-font-size: 12px;"/>
                </VBox>

                <Separator/>
                <Region prefHeight="15"/>

                <VBox fx:id="menuPrincipal" spacing="2"/>

                <Region prefHeight="20"/>

                <VBox fx:id="menuCursoContextual" spacing="2" visible="false" managed="false"/>

                <Region VBox.vgrow="ALWAYS"/>
                <Separator/>
                <Region prefHeight="8"/>

                <Button text="Cerrar sesión" maxWidth="Infinity" styleClass="flat, danger" onAction="#handleCerrarSesion"/>
            </VBox>
        </left>

        <center>
            <StackPane fx:id="areaPrincipal" style="-fx-background-color: -color-bg-default;"/>
        </center>
    </BorderPane>

    <StackPane fx:id="panelPerfilFlotante" visible="false" managed="false" style="-fx-background-color: rgba(0,0,0,0.4);">
        <VBox maxWidth="400" maxHeight="-Infinity" spacing="20" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5); -fx-padding: 30;">
            
            <Label text="Mi Perfil Estudiantil" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            
            <VBox spacing="5">
                <Label text="Nombre Completo" style="-fx-font-weight: bold;"/>
                <TextField fx:id="campoPerfilNombre" style="-fx-pref-height: 35;"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Correo Institucional" style="-fx-font-weight: bold;"/>
                <TextField fx:id="campoPerfilEmail" style="-fx-pref-height: 35;"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Cambiar Contraseña" style="-fx-font-weight: bold;"/>
                <PasswordField fx:id="campoPerfilPassword" promptText="Dejar en blanco para mantener la actual" style="-fx-pref-height: 35;"/>
            </VBox>

            <Label fx:id="mensajePerfil" visible="false" managed="false" wrapText="true"/>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button text="Cancelar" onAction="#handleCerrarPerfil" styleClass="flat"/>
                <Button text="Guardar Cambios" onAction="#handleGuardarPerfil" styleClass="accent"/>
            </HBox>
        </VBox>
    </StackPane>

</StackPane>