<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" style="-fx-background-color: #F3F4F6; -fx-padding: 28;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.academico.controller.AlumnoCursoDetalleController">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label fx:id="lblTituloMateria" text="Cargando materia..."
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            <Label text="Desglose detallado de tu evaluación en este curso."
                   style="-fx-text-fill: #6b7280; -fx-font-size: 13px;"/>
        </VBox>
        <VBox alignment="CENTER_RIGHT" spacing="4">
            <Label text="Estado de la Materia:"
                   style="-fx-text-fill: #6b7280; -fx-font-size: 12px;"/>
            <Label fx:id="lblEstadoCurso" text="ABIERTO"
                   style="-fx-font-weight: bold; -fx-font-size: 13px;
                          -fx-padding: 4 12; -fx-background-radius: 20;"/>
        </VBox>
    </HBox>

    <!-- Tabla unidades -->
    <VBox spacing="8" VBox.vgrow="ALWAYS">
        <Label text="Calificaciones por Unidad"
               style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #1a1a2e;"/>
        <TableView fx:id="tablaUnidades" VBox.vgrow="ALWAYS"
                   style="-fx-background-color: white;
                          -fx-background-radius: 10;
                          -fx-border-radius: 10;
                          -fx-border-color: #e5e7eb;
                          -fx-border-width: 1;
                          -fx-font-size: 13px;">
            <placeholder>
                <Label text="No hay calificaciones registradas aún."
                       style="-fx-text-fill: #6b7280; -fx-font-size: 13px;"/>
            </placeholder>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colUnidad" text="Unidad"/>
                <TableColumn fx:id="colCalificacion" text="Calificación" maxWidth="400"/>
                <TableColumn fx:id="colEstado" text="Estado" maxWidth="300"/>
                <TableColumn fx:id="colAcciones" text="Desglose" maxWidth="250"/>
            </columns>
        </TableView>
    </VBox>

    <Separator style="-fx-background-color: #e5e7eb;"/>

    <!-- Resumen general -->
    <VBox spacing="16"
          style="-fx-background-color: white;
                 -fx-padding: 20;
                 -fx-background-radius: 10;
                 -fx-border-color: #e5e7eb;
                 -fx-border-radius: 10;
                 -fx-border-width: 1;">

        <Label text="Resumen General"
               style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #1a1a2e;"/>

        <HBox spacing="24">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Promedio Matemático"
                       style="-fx-text-fill: #6b7280; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                <Label fx:id="lblPromedioBase" text="-"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            </VBox>

            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Bonus a la Materia"
                       style="-fx-text-fill: #6b7280; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                <Label fx:id="lblBonus" text="0.00 pts"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            </VBox>

            <VBox spacing="4" alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                <Label text="CALIFICACIÓN FINAL OFICIAL"
                       style="-fx-text-fill: #1a1a2e; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Label fx:id="lblCalificacionFinal" text="-"
                           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #00a896;"/>
                    <Label fx:id="lblEstadoFinal" text="PENDIENTE"
                           style="-fx-font-weight: bold;
                                  -fx-padding: 4 12;
                                  -fx-background-radius: 20;
                                  -fx-background-color: #e5e7eb;
                                  -fx-text-fill: #6b7280;
                                  -fx-font-size: 12px;"/>
                </HBox>
            </VBox>
        </HBox>

        <!-- Panel override -->
        <VBox fx:id="panelOverride" visible="false" managed="false" spacing="5"
              style="-fx-background-color: #fefce8;
                     -fx-padding: 14;
                     -fx-background-radius: 8;
                     -fx-border-color: #fbbf24;
                     -fx-border-radius: 8;
                     -fx-border-width: 1;">
            <Label text="Ajuste Manual Aplicado por el Docente"
                   style="-fx-font-weight: bold; -fx-text-fill: #92400e; -fx-font-size: 13px;"/>
            <Label text="Esta calificación final fue asignada directamente."
                   style="-fx-text-fill: #6b7280; -fx-font-size: 12px;"/>
            <Label fx:id="lblJustificacionOverride" wrapText="true"
                   style="-fx-font-style: italic; -fx-text-fill: #1a1a2e; -fx-font-size: 12px;"/>
        </VBox>
    </VBox>

</VBox>
