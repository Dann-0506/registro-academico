<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<VBox spacing="24" style="-fx-background-color: #F3F4F6; -fx-padding: 28;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.academico.controller.AnalisisController">

    <!-- Header -->
    <VBox spacing="4">
        <Label text="Análisis de Datos y Rendimiento"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
        <Label text="Métricas históricas y desempeño general de la institución."
               style="-fx-text-fill: #6b7280; -fx-font-size: 13px;"/>
    </VBox>

    <!-- Tarjetas métricas -->
    <HBox spacing="16">
        <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="8"
              style="-fx-background-color: white;
                     -fx-padding: 20;
                     -fx-background-radius: 10;
                     -fx-border-color: #e5e7eb;
                     -fx-border-radius: 10;
                     -fx-border-width: 1;">
            <Label text="Alumnos Registrados"
                   style="-fx-text-fill: #6b7280; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            <Label fx:id="lblTotalAlumnos" text="0"
                   style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #00a896;"/>
        </VBox>

        <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="8"
              style="-fx-background-color: white;
                     -fx-padding: 20;
                     -fx-background-radius: 10;
                     -fx-border-color: #e5e7eb;
                     -fx-border-radius: 10;
                     -fx-border-width: 1;">
            <Label text="Grupos Activos"
                   style="-fx-text-fill: #6b7280; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            <Label fx:id="lblGruposActivos" text="0"
                   style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #02c39a;"/>
        </VBox>

        <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="8"
              style="-fx-background-color: white;
                     -fx-padding: 20;
                     -fx-background-radius: 10;
                     -fx-border-color: #e5e7eb;
                     -fx-border-radius: 10;
                     -fx-border-width: 1;">
            <Label text="Materias en Catálogo"
                   style="-fx-text-fill: #6b7280; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            <Label fx:id="lblTotalMaterias" text="0"
                   style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #028090;"/>
        </VBox>
    </HBox>

    <!-- Gráfica -->
    <VBox VBox.vgrow="ALWAYS" spacing="12"
          style="-fx-background-color: white;
                 -fx-padding: 24;
                 -fx-background-radius: 10;
                 -fx-border-color: #e5e7eb;
                 -fx-border-radius: 10;
                 -fx-border-width: 1;">
        <Label text="Rendimiento de Aprobación por Semestre"
               style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #1a1a2e;"/>
        <BarChart fx:id="graficaRendimiento" VBox.vgrow="ALWAYS" animated="true" legendSide="BOTTOM">
            <xAxis>
                <CategoryAxis label="Semestre" fx:id="ejeX"/>
            </xAxis>
            <yAxis>
                <NumberAxis label="Cantidad de Alumnos" fx:id="ejeY"/>
            </yAxis>
        </BarChart>
    </VBox>

</VBox>
