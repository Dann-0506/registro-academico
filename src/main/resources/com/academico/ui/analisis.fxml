<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<VBox spacing="25" style="-fx-background-color: -color-bg-default; -fx-padding: 30;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.academico.controller.AnalisisController">

    <VBox spacing="5">
        <Label text="Análisis de Datos y Rendimiento" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #24292f;"/>
        <Label text="Métricas históricas y desempeño general de la institución." style="-fx-text-fill: #57606a; -fx-font-size: 14px;"/>
    </VBox>

    <HBox spacing="20">
        <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-border-color: #d0d7de; -fx-border-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);">
            <Label text="Alumnos Registrados" style="-fx-text-fill: #57606a; -fx-font-weight: bold;"/>
            <Label fx:id="lblTotalAlumnos" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #0969da;"/>
        </VBox>
        
        <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-border-color: #d0d7de; -fx-border-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);">
            <Label text="Grupos Activos" style="-fx-text-fill: #57606a; -fx-font-weight: bold;"/>
            <Label fx:id="lblGruposActivos" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #2da44e;"/>
        </VBox>

        <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-border-color: #d0d7de; -fx-border-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);">
            <Label text="Materias en Catálogo" style="-fx-text-fill: #57606a; -fx-font-weight: bold;"/>
            <Label fx:id="lblTotalMaterias" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #8250df;"/>
        </VBox>
    </HBox>

    <VBox VBox.vgrow="ALWAYS" spacing="15" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 8; -fx-border-color: #d0d7de; -fx-border-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);">
        <Label text="Rendimiento de Aprobación por Semestre" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #24292f;"/>
        
        <BarChart fx:id="graficaRendimiento" VBox.vgrow="ALWAYS" animated="true" legendSide="BOTTOM">
            <xAxis>
                <CategoryAxis label="Semestre" fx:id="ejeX"/>
            </xAxis>
            <yAxis>
                <NumberAxis label="Cantidad de Alumnos" fx:id="ejeY"/>
            </yAxis>
        </BarChart>
    </VBox>

</VBox>