<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.academico.controller.AlumnosController">

    <VBox spacing="20" style="-fx-padding: 28; -fx-background-color: #F3F4F6;">

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="12">
            <Label text="Catálogo de Alumnos"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Importar CSV" onAction="#handleImportarCsv"
                    style="-fx-pref-height: 36;
                           -fx-background-color: white;
                           -fx-border-color: #d1d5db;
                           -fx-border-width: 1;
                           -fx-border-radius: 8;
                           -fx-background-radius: 8;
                           -fx-font-size: 13px;
                           -fx-cursor: hand;">
                <tooltip>
                    <Tooltip text="Formato esperado:&#10;• MATRÍCULA&#10;• NOMBRE COMPLETO&#10;• CORREO"/>
                </tooltip>
            </Button>
            <TextField fx:id="campoBusqueda"
                       promptText="Buscar por nombre o matrícula..."
                       onKeyReleased="#handleBusqueda"
                       prefWidth="250"
                       style="-fx-pref-height: 36;
                              -fx-background-radius: 8;
                              -fx-border-radius: 8;
                              -fx-border-color: #d1d5db;
                              -fx-border-width: 1;
                              -fx-font-size: 13px;
                              -fx-background-color: white;"/>
            <Button text="+ Nuevo Alumno" onAction="#handleNuevo"
                    style="-fx-pref-height: 36;
                           -fx-font-weight: bold;
                           -fx-font-size: 13px;
                           -fx-background-color: #00a896;
                           -fx-text-fill: white;
                           -fx-background-radius: 8;
                           -fx-border-width: 0;
                           -fx-cursor: hand;
                           -fx-padding: 0 16;"/>
        </HBox>

        <!-- Tabla -->
        <TableView fx:id="tablaAlumnos" VBox.vgrow="ALWAYS"
                   style="-fx-background-color: white;
                          -fx-background-radius: 10;
                          -fx-border-radius: 10;
                          -fx-border-color: #e5e7eb;
                          -fx-border-width: 1;
                          -fx-font-size: 13px;">
            <placeholder>
                <Label text="No se encontraron alumnos registrados."
                       style="-fx-text-fill: #6b7280; -fx-font-size: 13px;"/>
            </placeholder>
            <columns>
                <TableColumn fx:id="colMatricula" text="Matrícula" prefWidth="150"/>
                <TableColumn fx:id="colNombre" text="Nombre Completo" prefWidth="300"/>
                <TableColumn fx:id="colEmail" text="Correo Electrónico" prefWidth="250"/>
                <TableColumn fx:id="colEstado" text="Estado" prefWidth="100"
                             style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="colAcciones" text="Acciones" prefWidth="220"
                             style="-fx-alignment: CENTER;"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_FLEX_LAST_COLUMN"/>
            </columnResizePolicy>
        </TableView>

        <Pagination fx:id="paginacionAlumnos" maxPageIndicatorCount="5"/>

    </VBox>

    <!-- Modal formulario -->
    <StackPane fx:id="panelFormulario" visible="false" managed="false"
               style="-fx-background-color: rgba(0,0,0,0.4);">
        <VBox maxWidth="450" maxHeight="-Infinity" spacing="20"
              style="-fx-background-color: white;
                     -fx-background-radius: 12;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5);
                     -fx-padding: 30;">

            <Label fx:id="labelTituloFormulario" text="Nuevo Alumno"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>

            <VBox spacing="5">
                <Label text="Matrícula *" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                <TextField fx:id="campoMatricula" promptText="Ej. 20230001"
                           style="-fx-pref-height: 36;
                                  -fx-background-radius: 8;
                                  -fx-border-radius: 8;
                                  -fx-border-color: #d1d5db;
                                  -fx-border-width: 1;
                                  -fx-font-size: 13px;"/>
                <Label fx:id="errorMatricula"
                       style="-fx-text-fill: #ef4444; -fx-font-size: 12px;"
                       visible="false" managed="false"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Nombre Completo *" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                <TextField fx:id="campoNombre" promptText="Ej. Juan Pérez García"
                           style="-fx-pref-height: 36;
                                  -fx-background-radius: 8;
                                  -fx-border-radius: 8;
                                  -fx-border-color: #d1d5db;
                                  -fx-border-width: 1;
                                  -fx-font-size: 13px;"/>
                <Label fx:id="errorNombre"
                       style="-fx-text-fill: #ef4444; -fx-font-size: 12px;"
                       visible="false" managed="false"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Correo Electrónico" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                <TextField fx:id="campoEmail" promptText="ejemplo@escuela.edu"
                           style="-fx-pref-height: 36;
                                  -fx-background-radius: 8;
                                  -fx-border-radius: 8;
                                  -fx-border-color: #d1d5db;
                                  -fx-border-width: 1;
                                  -fx-font-size: 13px;"/>
                <Label fx:id="errorEmail"
                       style="-fx-text-fill: #ef4444; -fx-font-size: 12px;"
                       visible="false" managed="false"/>
            </VBox>

            <Label fx:id="labelNotaPassword"
                   text="Nota: Los alumnos nuevos se crean con la contraseña predeterminada '123456'."
                   style="-fx-text-fill: #6b7280; -fx-font-size: 11px;"
                   wrapText="true"/>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button fx:id="btnRestablecerPassword" text="Restablecer Contraseña"
                        onAction="#handleRestablecerPassword"
                        visible="false" managed="false"
                        style="-fx-pref-height: 36;
                               -fx-background-color: white;
                               -fx-border-color: #fca5a5;
                               -fx-border-width: 1;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-text-fill: #dc2626;
                               -fx-font-size: 13px;
                               -fx-cursor: hand;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Cancelar" onAction="#handleCancelar"
                        style="-fx-pref-height: 36;
                               -fx-background-color: white;
                               -fx-border-color: #d1d5db;
                               -fx-border-width: 1;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-font-size: 13px;
                               -fx-cursor: hand;"/>
                <Button fx:id="botonGuardar" text="Guardar" onAction="#handleGuardar"
                        style="-fx-pref-height: 36;
                               -fx-background-color: #00a896;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-border-width: 0;
                               -fx-font-size: 13px;
                               -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </StackPane>

    <Label fx:id="mensajeGeneral" visible="false" managed="false" wrapText="true"
           StackPane.alignment="BOTTOM_CENTER"
           style="-fx-translate-y: -40;
                  -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 15, 0, 0, 5);
                  -fx-background-radius: 8;
                  -fx-padding: 10 16;
                  -fx-font-size: 13px;"/>

    <!-- Modal confirmación -->
    <StackPane fx:id="panelConfirmacion" visible="false" managed="false"
               style="-fx-background-color: rgba(0,0,0,0.5);">
        <VBox maxWidth="400" maxHeight="-Infinity" spacing="15"
              style="-fx-background-color: white;
                     -fx-background-radius: 12;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5);
                     -fx-padding: 30;">

            <Label fx:id="lblTituloConfirmacion"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            <Label fx:id="lblMensajeConfirmacion" wrapText="true"
                   style="-fx-text-fill: #6b7280; -fx-font-size: 14px;"/>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button text="Cancelar" onAction="#handleCancelarConfirmacion"
                        style="-fx-pref-height: 36;
                               -fx-background-color: white;
                               -fx-border-color: #d1d5db;
                               -fx-border-width: 1;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-font-size: 13px;
                               -fx-cursor: hand;"/>
                <Button fx:id="btnConfirmarAccion" text="Confirmar"
                        onAction="#handleEjecutarConfirmacion"
                        style="-fx-pref-height: 36;
                               -fx-background-color: #00a896;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-border-width: 0;
                               -fx-font-size: 13px;
                               -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </StackPane>

</StackPane>
