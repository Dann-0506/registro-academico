<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.academico.controller.LoginController"
           style="-fx-background-color: #F3F4F6;">

    <HBox maxWidth="640" maxHeight="380"
          style="-fx-background-color: white;
                 -fx-background-radius: 16;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 24, 0, 0, 4);">

        <!-- Panel izquierdo turquesa -->
        <StackPane HBox.hgrow="ALWAYS"
                   style="-fx-background-color: #00a896;
                          -fx-background-radius: 16 0 0 16;">

            <!-- Círculos decorativos -->
            <Circle radius="110" translateX="70" translateY="-90"
                    style="-fx-fill: rgba(255,255,255,0.08);"/>
            <Circle radius="60" translateX="70" translateY="-10"
                    style="-fx-fill: rgba(255,255,255,0.06);"/>
            <Circle radius="90" translateX="-80" translateY="60"
                    style="-fx-fill: rgba(2,195,154,0.4);"/>

            <!-- Contenido -->
            <VBox alignment="CENTER_LEFT" spacing="8">
                <padding><Insets top="0" right="40" bottom="0" left="40"/></padding>

                <Label text="SIRA"
                       style="-fx-text-fill: white;
                              -fx-font-size: 52px;
                              -fx-font-weight: bold;"/>

                <Label text="Sistema Institucional de"
                       style="-fx-text-fill: rgba(255,255,255,0.9);
                              -fx-font-size: 15px;
                              -fx-font-weight: bold;"/>
                <Label text="Registro Académico"
                       style="-fx-text-fill: rgba(255,255,255,0.9);
                              -fx-font-size: 15px;
                              -fx-font-weight: bold;"/>
            </VBox>
        </StackPane>

        <!-- Panel derecho blanco -->
        <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="16"
              style="-fx-background-color: white;
                     -fx-background-radius: 0 16 16 0;">
            <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

            <!-- Encabezado -->
            <VBox spacing="4" alignment="CENTER_LEFT" maxWidth="Infinity">
                <Label text="Iniciar sesión"
                       style="-fx-font-size: 20px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #1a1a2e;"/>
                <Label text="Accede con tu cuenta institucional"
                       style="-fx-font-size: 13px;
                              -fx-text-fill: #6b7280;"/>
            </VBox>

            <!-- Campo correo -->
            <VBox spacing="4" maxWidth="Infinity">
                <Label text="Correo electrónico"
                       style="-fx-font-size: 12px;
                              -fx-text-fill: #6b7280;"/>
                <TextField fx:id="campEmail"
                           promptText="usuario@institucion.edu"
                           style="-fx-pref-height: 36;
                                  -fx-background-radius: 8;
                                  -fx-border-radius: 8;
                                  -fx-border-color: #d1d5db;
                                  -fx-border-width: 1;
                                  -fx-font-size: 13px;"/>
                <Label fx:id="errorEmail"
                       style="-fx-text-fill: #ef4444; -fx-font-size: 12px;"
                       visible="false" managed="false"/>
            </VBox>

            <!-- Campo contraseña -->
            <VBox spacing="4" maxWidth="Infinity">
                <Label text="Contraseña"
                       style="-fx-font-size: 12px;
                              -fx-text-fill: #6b7280;"/>
                <PasswordField fx:id="campPassword"
                               promptText="••••••••"
                               style="-fx-pref-height: 36;
                                      -fx-background-radius: 8;
                                      -fx-border-radius: 8;
                                      -fx-border-color: #d1d5db;
                                      -fx-border-width: 1;
                                      -fx-font-size: 13px;"/>
                <Label fx:id="errorPassword"
                       style="-fx-text-fill: #ef4444; -fx-font-size: 12px;"
                       visible="false" managed="false"/>
            </VBox>

            <Label fx:id="errorGeneral"
                   style="-fx-text-fill: #ef4444; -fx-font-size: 12px;"
                   wrapText="true" visible="false" managed="false"/>

            <!-- Botón -->
            <Button fx:id="botonLogin"
                    text="Iniciar sesión"
                    maxWidth="Infinity"
                    defaultButton="true"
                    onAction="#handleLogin"
                    style="-fx-pref-height: 40;
                           -fx-font-size: 14px;
                           -fx-font-weight: bold;
                           -fx-cursor: hand;
                           -fx-background-color: #00a896;
                           -fx-background-radius: 8;
                           -fx-text-fill: white;
                           -fx-border-width: 0;">
                <VBox.margin><Insets top="4"/></VBox.margin>
            </Button>

        </VBox>
    </HBox>
</StackPane>
